---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "OCM — Open Church Management documentation." } = Astro.props;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Getting Started", href: "/getting-started" },
  { label: "Tutorial", href: "/tutorial" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — OCM Docs</title>
  </head>

  <body>
    <!-- ── Navbar ── -->
    <header class="fixed w-full top-0 z-50">
      <nav
        class="w-full flex items-center justify-between backdrop-blur-md border-b px-6 sm:px-10 h-20"
        style="background-color: var(--color-porcelain); opacity: 0.97; border-color: var(--color-border);"
        aria-label="Primary"
      >
        <div class="flex items-center gap-8 h-full">
          <a
            href="/"
            class="font-cormorant text-2xl font-semibold tracking-[0.15em] transition-colors"
            style="color: var(--color-text-strong); font-family: 'Cormorant Garamond', serif;"
            aria-label="OCM Docs — home"
          >
            O<span style="color: var(--color-gold);">C</span>M
            <span
              class="ml-2 text-sm font-light tracking-widest uppercase"
              style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
            >Docs</span>
          </a>

          <ul class="hidden sm:flex items-center gap-1 h-full" role="list">
            {navLinks.map(({ label, href }) => {
              const isActive = currentPath === href;
              return (
                <li class="h-full flex items-center">
                  <a
                    href={href}
                    class="text-xs uppercase tracking-[0.18em] px-4 py-2 border-b-2 flex items-center h-full transition-all"
                    style={`font-family: 'Inter', sans-serif; color: ${isActive ? "var(--color-gold)" : "var(--color-text-strong)"}; border-color: ${isActive ? "var(--color-gold)" : "transparent"};`}
                  >
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        <a
          href="https://github.com/kibetnathan/O-Concord"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-[0.18em] px-4 py-2 border transition-all"
          style="font-family: 'Inter', sans-serif; color: var(--color-text-strong); border-color: var(--color-border);"
        >GitHub</a>
      </nav>
    </header>

    <!-- ── Page content ── -->
    <main id="main-content" class="pt-20">
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer
      class="border-t px-6 sm:px-10 lg:px-16 py-12 mt-20"
      style="background-color: var(--color-porcelain); border-color: var(--color-border);"
    >
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-start justify-between gap-8">
        <div>
          <p
            class="font-semibold text-xl tracking-[0.15em] mb-2"
            style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
          >
            O<span style="color: var(--color-gold);">C</span>M
          </p>
          <p class="text-xs" style="font-family: 'Inter', sans-serif; color: var(--color-khaki);">
            Open source church management. Free forever.
          </p>
        </div>

        <nav aria-label="Footer links">
          <ul class="flex flex-wrap gap-6" role="list">
            {[
              { label: "Getting Started", href: "/getting-started" },
              { label: "Tutorial", href: "/tutorial" },
              { label: "GitHub", href: "https://github.com/kibetnathan/O-Concord" },
              { label: "MIT License", href: "https://opensource.org/licenses/MIT" },
            ].map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target={href.startsWith("http") ? "_blank" : undefined}
                  rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="footer-link text-xs uppercase tracking-[0.15em] transition-colors"
                  style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </footer>

    <style>
      nav a:hover { color: var(--color-gold) !important; }
      .footer-link:hover { color: var(--color-gold) !important; }
    </style>
  </body>
</html>
