---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="OCM — Open Church Management. Free, open-source church management system built with React and Django."
    />
    <title>OCM Docs — Open Church Management</title>
  </head>

  <body>
    <!-- ── Navbar ── -->
    <header class="fixed w-full top-0 z-50">
      <nav
        class="w-full flex items-center justify-between backdrop-blur-md border-b px-6 sm:px-10 h-20"
        style="background-color: var(--color-porcelain); opacity: 0.97; border-color: var(--color-border);"
        aria-label="Primary"
      >
        <a
          href="/"
          class="font-cormorant text-2xl font-semibold tracking-[0.15em] transition-colors"
          style="color: var(--color-text-strong); font-family: 'Cormorant Garamond', serif;"
          aria-label="OCM Docs — home"
        >
          O<span style="color: var(--color-gold);">C</span>M
          <span
            class="ml-2 text-sm font-light tracking-widest uppercase"
            style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
          >Docs</span>
        </a>

        <ul class="hidden sm:flex items-center gap-1 h-full" role="list">
          <li class="h-full flex items-center">
            <a
              href="#about"
              class="nav-link text-xs uppercase tracking-[0.18em] px-4 py-2 transition-all"
              style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
            >About</a>
          </li>
          <li class="h-full flex items-center">
            <a
              href="/getting-started"
              class="nav-link text-xs uppercase tracking-[0.18em] px-4 py-2 transition-all"
              style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
            >Getting Started</a>
          </li>
          <li class="h-full flex items-center">
            <a
              href="/tutorial"
              class="nav-link text-xs uppercase tracking-[0.18em] px-4 py-2 transition-all"
              style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
            >Tutorial</a>
          </li>
          <li class="h-full flex items-center">
            <a
              href="#stack"
              class="nav-link text-xs uppercase tracking-[0.18em] px-4 py-2 transition-all"
              style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
            >Tech Stack</a>
          </li>
          <li class="h-full flex items-center">
            <a
              href="https://github.com/kibetnathan/O-Concord"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs uppercase tracking-[0.18em] px-4 py-2 transition-all border"
              style="font-family: 'Inter', sans-serif; color: var(--color-text-strong); border-color: var(--color-border);"
            >GitHub</a>
          </li>
        </ul>

        <!-- Mobile GitHub -->
        <a
          href="https://github.com/kibetnathan/O-Concord"
          target="_blank"
          rel="noopener noreferrer"
          class="sm:hidden text-xs uppercase tracking-[0.18em] px-3 py-2 border transition-all"
          style="font-family: 'Inter', sans-serif; color: var(--color-text-strong); border-color: var(--color-border);"
        >GitHub</a>
      </nav>
    </header>

    <main id="main-content">
      <!-- ── Hero ── -->
      <header
        class="relative min-h-screen w-full flex items-center pt-20"
        style="background: linear-gradient(135deg, #1a1612 0%, #2a1f14 40%, #1a1612 100%);"
      >
        <!-- Subtle grain overlay -->
        <div
          class="absolute inset-0 pointer-events-none"
          style="background-image: radial-gradient(ellipse at 20% 50%, rgba(200,150,12,0.08) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(200,150,12,0.05) 0%, transparent 50%); z-index: 1;"
        ></div>

        <!-- Thin gold top border accent -->
        <div
          class="absolute top-20 left-0 right-0 h-px"
          style="background: linear-gradient(to right, transparent, var(--color-gold), transparent); z-index: 2;"
        ></div>

        <div class="relative w-full px-6 sm:px-10 lg:px-16 py-20 sm:py-28" style="z-index: 2;">
          <div class="max-w-3xl">
            <span
              class="text-xs uppercase tracking-[0.28em] mb-6 block"
              style="color: var(--color-gold); font-family: 'Inter', sans-serif;"
            >
              — Open Source Church Management
            </span>

            <h1
              class="mb-6 text-5xl sm:text-6xl lg:text-[4rem] font-light leading-tight"
              style="font-family: 'Cormorant Garamond', serif; color: #fffef6;"
            >
              Build your church's<br />
              <span
                class="italic font-semibold"
                style="color: var(--color-gold);"
              >management platform.</span>
            </h1>

            <p
              class="mb-10 text-base sm:text-lg leading-relaxed max-w-xl"
              style="color: rgba(245,240,235,0.75); font-family: 'Inter', sans-serif;"
            >
              OCM is a free, open-source system built for real churches — connecting
              members, leadership, fellowship groups, and discipleship courses
              in one place. Fork it, self-host it, and make it yours.
            </p>

            <div class="flex flex-wrap gap-4">
              <!-- Download button — link will be added once zip is ready -->
              <button
                type="button"
                disabled
                class="inline-flex items-center gap-2.5 text-sm uppercase tracking-[0.18em] px-8 py-4 transition-all cursor-not-allowed"
                style="background-color: var(--color-gold); color: #1a1612; font-family: 'Inter', sans-serif; opacity: 0.6;"
                title="Download coming soon"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Download ZIP
              </button>

              <a
                href="https://github.com/kibetnathan/O-Concord"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2.5 text-sm uppercase tracking-[0.18em] px-8 py-4 border transition-all"
                style="border-color: rgba(245,240,235,0.25); color: rgba(245,240,235,0.85); font-family: 'Inter', sans-serif;"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                  ></path>
                </svg>
                View on GitHub
              </a>
            </div>
          </div>
        </div>

        <!-- Scroll hint -->
        <div
          class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40"
          aria-hidden="true"
          style="z-index: 2;"
        >
          <span class="text-xs uppercase tracking-[0.2em]" style="color: var(--color-khaki); font-family: 'Inter', sans-serif;">Scroll</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-khaki)" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <polyline points="19 12 12 19 5 12" />
          </svg>
        </div>
      </header>

      <!-- ── About ── -->
      <section
        id="about"
        aria-labelledby="about-heading"
        class="border-b px-6 sm:px-10 lg:px-16 py-20 sm:py-28"
        style="background-color: var(--color-ivory); border-color: var(--color-border);"
      >
        <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-14 lg:gap-24 items-start">
          <div class="lg:w-5/12 shrink-0">
            <p
              class="text-xs uppercase tracking-[0.22em] mb-3"
              style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
            >
              About the Project
            </p>
            <h2
              id="about-heading"
              class="text-4xl sm:text-5xl font-light leading-tight"
              style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
            >
              Built for real churches.<br />
              <span
                class="italic"
                style="color: var(--color-gold);"
              >Free for any congregation.</span>
            </h2>
            <div
              class="w-8 h-0.5 mt-5"
              style="background-color: var(--color-gold);"
              aria-hidden="true"
            ></div>
          </div>

          <div class="lg:w-7/12 flex flex-col gap-5">
            <p
              class="text-base sm:text-lg leading-relaxed"
              style="color: var(--color-text-primary); font-family: 'Inter', sans-serif;"
            >
              OCM was designed around how a real church actually operates — with
              fellowship groups, serving departments, discipleship courses, and a
              leadership structure that values both accountability and flexibility.
            </p>
            <p
              class="text-base sm:text-lg leading-relaxed"
              style="color: var(--color-text-primary); font-family: 'Inter', sans-serif;"
            >
              It's open source so any congregation can adapt it to their own needs
              without paying for enterprise software. Self-host it on your own
              infrastructure, or fork and deploy to Vercel + Render in minutes.
            </p>
            <div class="flex flex-wrap gap-3 mt-2">
              {["100% Open Source", "Self-hostable", "No vendor lock-in", "MIT Licensed"].map((tag) => (
                <span
                  class="text-xs uppercase tracking-[0.15em] px-3 py-1.5 border"
                  style={`font-family: 'Inter', sans-serif; color: var(--color-text-primary); border-color: var(--color-border);`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ── Stats bar ── -->
      <section
        aria-label="Platform highlights"
        class="mx-6 sm:mx-10 my-10 rounded-sm px-6 sm:px-10 lg:px-16 py-12"
        style="background-color: var(--color-gold);"
      >
        <ul
          role="list"
          class="max-w-6xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-8"
        >
          {[
            { value: "2", label: "App layers" },
            { value: "5+", label: "Grouping models" },
            { value: "100%", label: "Open Source" },
            { value: "MIT", label: "License" },
          ].map(({ value, label }) => (
            <li class="flex flex-col items-center text-center">
              <p
                class="text-4xl sm:text-5xl font-light"
                style="font-family: 'Cormorant Garamond', serif; color: #1a1612;"
              >
                {value}
              </p>
              <p
                class="text-xs uppercase tracking-widest mt-1"
                style="font-family: 'Inter', sans-serif; color: rgba(26,22,18,0.75);"
              >
                {label}
              </p>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── Features ── -->
      <section
        aria-labelledby="features-heading"
        class="px-6 sm:px-10 lg:px-16 py-20 sm:py-28"
        style="background-color: var(--color-ivory);"
      >
        <div class="max-w-6xl mx-auto">
          <div class="mb-12">
            <p
              class="text-xs uppercase tracking-[0.22em] mb-2"
              style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
            >
              What's Inside
            </p>
            <h2
              id="features-heading"
              class="text-4xl sm:text-5xl font-light"
              style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
            >
              Platform Features
            </h2>
            <div
              class="w-8 h-0.5 mt-4"
              style="background-color: var(--color-gold);"
              aria-hidden="true"
            ></div>
          </div>

          <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {[
              {
                number: "01",
                title: "Fellowship Groups",
                body: "Organise members into fellowship groups. Leaders manage membership and group activities from the dashboard.",
              },
              {
                number: "02",
                title: "Serving Departments",
                body: "Track which members serve in worship, hospitality, media, or ushering. Assign crew to services and manage equipment.",
              },
              {
                number: "03",
                title: "Discipleship Courses",
                body: "Run structured courses — track enrolment, progress, and completion across different cohorts of members.",
              },
              {
                number: "04",
                title: "Role-Based Access",
                body: "Pastors, Leaders, and Staff get full dashboard access. Members see their own groups and feed — no data leaks.",
              },
              {
                number: "05",
                title: "Community Feed",
                body: "A shared feed for posts, announcements, and updates. Members can react and comment; leaders can broadcast church-wide.",
              },
              {
                number: "06",
                title: "Bible & Reading Plans",
                body: "Built-in Bible reader with verse memorisation (spaced repetition) and reading plans members can join and track.",
              },
            ].map(({ number, title, body }) => (
              <li>
                <article
                  class="h-full border p-6 transition-all group feature-card"
                  style={`background-color: var(--color-ivory); border-color: var(--color-border);`}
                >
                  <p
                    class="text-3xl font-light mb-4 transition-colors"
                    style={`font-family: 'Cormorant Garamond', serif; color: var(--color-gold); opacity: 0.6;`}
                    aria-hidden="true"
                  >
                    {number}
                  </p>
                  <h3
                    class="text-2xl font-semibold mb-2"
                    style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
                  >
                    {title}
                  </h3>
                  <p
                    class="text-sm leading-relaxed"
                    style="font-family: 'Inter', sans-serif; color: var(--color-text-primary);"
                  >
                    {body}
                  </p>
                </article>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ── Tech Stack ── -->
      <section
        id="stack"
        aria-labelledby="stack-heading"
        class="border-y px-6 sm:px-10 lg:px-16 py-20 sm:py-28"
        style="background-color: var(--color-porcelain); border-color: var(--color-border);"
      >
        <div class="max-w-6xl mx-auto">
          <div class="mb-12">
            <p
              class="text-xs uppercase tracking-[0.22em] mb-2"
              style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
            >
              Under the Hood
            </p>
            <h2
              id="stack-heading"
              class="text-4xl sm:text-5xl font-light"
              style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
            >
              Tech Stack
            </h2>
            <div
              class="w-8 h-0.5 mt-4"
              style="background-color: var(--color-gold);"
              aria-hidden="true"
            ></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Frontend -->
            <article
              class="border p-8"
              style="background-color: var(--color-ivory); border-color: var(--color-border);"
              aria-labelledby="stack-frontend"
            >
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-1 h-6 rounded-full"
                  style="background-color: var(--color-gold);"
                  aria-hidden="true"
                ></div>
                <h3
                  id="stack-frontend"
                  class="text-xl font-semibold uppercase tracking-[0.12em]"
                  style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
                >
                  Frontend
                </h3>
              </div>
              <ul class="flex flex-col gap-3">
                {[
                  ["React 19", "UI library"],
                  ["React Router v7", "Client-side routing"],
                  ["Zustand 5", "State management"],
                  ["Tailwind CSS 4 + DaisyUI 5", "Styling"],
                  ["MUI Material 7", "Component library"],
                  ["Vite 7", "Build tool"],
                  ["Firebase SDK 12", "Auth + Firestore"],
                ].map(([name, desc]) => (
                  <li class="flex items-baseline justify-between gap-4 py-2 border-b last:border-0" style="border-color: var(--color-border);">
                    <span
                      class="text-sm font-medium"
                      style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
                    >
                      {name}
                    </span>
                    <span
                      class="text-xs shrink-0"
                      style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
                    >
                      {desc}
                    </span>
                  </li>
                ))}
              </ul>
            </article>

            <!-- Backend -->
            <article
              class="border p-8"
              style="background-color: var(--color-ivory); border-color: var(--color-border);"
              aria-labelledby="stack-backend"
            >
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-1 h-6 rounded-full"
                  style="background-color: var(--color-gold);"
                  aria-hidden="true"
                ></div>
                <h3
                  id="stack-backend"
                  class="text-xl font-semibold uppercase tracking-[0.12em]"
                  style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
                >
                  Backend
                </h3>
              </div>
              <ul class="flex flex-col gap-3">
                {[
                  ["Django 6", "Web framework"],
                  ["Django REST Framework 3", "API layer"],
                  ["Firebase Admin SDK", "Token validation"],
                  ["PostgreSQL", "Production database"],
                  ["Cloudinary", "Media storage"],
                  ["Gunicorn + Uvicorn", "ASGI server"],
                  ["Paystack", "Payment processing"],
                ].map(([name, desc]) => (
                  <li class="flex items-baseline justify-between gap-4 py-2 border-b last:border-0" style="border-color: var(--color-border);">
                    <span
                      class="text-sm font-medium"
                      style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
                    >
                      {name}
                    </span>
                    <span
                      class="text-xs shrink-0"
                      style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
                    >
                      {desc}
                    </span>
                  </li>
                ))}
              </ul>
            </article>
          </div>
        </div>
      </section>

      <!-- ── Quick Start ── -->
      <section
        id="quickstart"
        aria-labelledby="quickstart-heading"
        class="px-6 sm:px-10 lg:px-16 py-20 sm:py-28"
        style="background-color: var(--color-ivory);"
      >
        <div class="max-w-6xl mx-auto">
          <div class="mb-12">
            <p
              class="text-xs uppercase tracking-[0.22em] mb-2"
              style="color: var(--color-khaki); font-family: 'Inter', sans-serif;"
            >
              Get Up and Running
            </p>
            <h2
              id="quickstart-heading"
              class="text-4xl sm:text-5xl font-light"
              style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
            >
              Quick Start
            </h2>
            <div
              class="w-8 h-0.5 mt-4"
              style="background-color: var(--color-gold);"
              aria-hidden="true"
            ></div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
            <!-- Frontend -->
            <div>
              <h3
                class="text-xl font-semibold mb-4 flex items-center gap-2"
                style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
              >
                <span
                  class="w-5 h-5 rounded-full inline-flex items-center justify-center text-xs font-bold shrink-0"
                  style="background-color: var(--color-gold); color: #1a1612;"
                >1</span>
                Frontend
              </h3>
              <pre class="text-sm leading-relaxed">
<code># Clone and install
git clone https://github.com/kibetnathan/O-Concord
cd ocm-fullstack/frontend
npm install

# Add your env vars (see docs)
cp .env.example .env.local

# Start dev server
npm run dev</code>
              </pre>
            </div>

            <!-- Backend -->
            <div>
              <h3
                class="text-xl font-semibold mb-4 flex items-center gap-2"
                style="font-family: 'Inter', sans-serif; color: var(--color-text-strong);"
              >
                <span
                  class="w-5 h-5 rounded-full inline-flex items-center justify-center text-xs font-bold shrink-0"
                  style="background-color: var(--color-gold); color: #1a1612;"
                >2</span>
                Backend
              </h3>
              <pre class="text-sm leading-relaxed">
<code># In a separate terminal
cd ocm-fullstack/backend
pip install -r requirements.txt

# Add your env vars + firebase-key.json
python manage.py migrate
python manage.py runserver</code>
              </pre>
            </div>
          </div>

          <div
            class="mt-10 p-5 border-l-2 text-sm"
            style="border-color: var(--color-gold); background-color: var(--color-porcelain); font-family: 'Inter', sans-serif; color: var(--color-text-primary);"
          >
            <strong style="color: var(--color-text-strong);">Before you start:</strong> You'll need a Firebase project (for Auth + Firestore), a Cloudinary account (media uploads), and a PostgreSQL database for production. See the full setup guide for environment variable details.
          </div>
        </div>
      </section>

      <!-- ── CTA ── -->
      <section
        aria-labelledby="cta-heading"
        class="mx-6 sm:mx-10 mb-10 rounded-sm px-6 sm:px-10 lg:px-24 py-16 sm:py-20"
        style="background-color: var(--color-gold);"
      >
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-8">
          <div>
            <h2
              id="cta-heading"
              class="text-3xl sm:text-4xl font-semibold leading-tight"
              style="font-family: 'Cormorant Garamond', serif; color: #1a1612;"
            >
              Ready to deploy?
            </h2>
            <p
              class="text-sm mt-2 tracking-wide"
              style="font-family: 'Inter', sans-serif; color: rgba(26,22,18,0.75);"
            >
              Download the release or fork the repo and adapt it for your congregation.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 shrink-0">
            <!-- Download button — no href until zip is ready -->
            <button
              type="button"
              disabled
              class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] px-8 py-4 transition-all cursor-not-allowed"
              style="background-color: #1a1612; color: #fffef6; font-family: 'Inter', sans-serif; opacity: 0.5;"
              title="Download coming soon"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Download ZIP
            </button>

            <a
              href="https://github.com/kibetnathan/O-Concord"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] px-8 py-4 border transition-all"
              style="border-color: rgba(26,22,18,0.4); color: #1a1612; font-family: 'Inter', sans-serif;"
            >
              Fork on GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer ── -->
    <footer
      class="border-t px-6 sm:px-10 lg:px-16 py-12"
      style="background-color: var(--color-porcelain); border-color: var(--color-border);"
    >
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-start justify-between gap-8">
        <div>
          <p
            class="font-semibold text-xl tracking-[0.15em] mb-2"
            style="font-family: 'Cormorant Garamond', serif; color: var(--color-text-strong);"
          >
            O<span style="color: var(--color-gold);">C</span>M
          </p>
          <p
            class="text-xs"
            style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
          >
            Open Church Management — free for any congregation.
          </p>
        </div>

        <nav aria-label="Footer links">
          <ul class="flex flex-wrap gap-6" role="list">
            {[
              { label: "Getting Started", href: "/getting-started" },
              { label: "Tutorial", href: "/tutorial" },
              { label: "GitHub", href: "https://github.com/kibetnathan/O-Concord" },
              { label: "MIT License", href: "https://opensource.org/licenses/MIT" },
            ].map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target={href.startsWith("http") ? "_blank" : undefined}
                  rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="text-xs uppercase tracking-[0.15em] transition-colors"
                  style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <p
          class="text-xs"
          style="font-family: 'Inter', sans-serif; color: var(--color-khaki);"
        >
          Open source. Free forever.
        </p>
      </div>
    </footer>

    <style>
      /* Nav link hover */
      .nav-link:hover {
        color: var(--color-gold) !important;
      }

      /* Feature card hover */
      .feature-card:hover {
        border-color: var(--color-gold) !important;
        box-shadow: 0 4px 20px rgba(200, 150, 12, 0.08);
      }

      /* Footer link hover */
      footer a:hover {
        color: var(--color-gold) !important;
      }

      /* Nav border hover */
      nav a:hover {
        color: var(--color-gold) !important;
      }

      /* Smooth scroll */
      html {
        scroll-behavior: smooth;
      }
    </style>
  </body>
</html>
